# Here, you configure against which FE/BE you're running playwright
APP_FRONTEND_HOST = http://127.0.0.1:3000
APP_BACKEND_HOST = http://127.0.0.1:8080

# Admin user credentials for the instance you're testing
ADMIN_USERNAME = admin
ADMIN_PASSWORD = aula

# Use these envvars to cleanup and bootstrap the Database
DB_NAME=aula_database
DB_USER=aula_user
DB_PASS=e2e_pass
# it's safer to use 127.0.0.1 than localhost
DB_HOST=127.0.0.1
DB_PORT=3307
